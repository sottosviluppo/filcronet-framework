{
  "name": "filcronet-framework",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev": "pnpm -r --parallel --filter './packages/*' run dev",
    "clean": "pnpm -r --filter './packages/*' run clean",
    "clean:all": "rimraf packages/*/dist packages/*/node_modules node_modules",
    "version:patch": "pnpm -r --filter './packages/*' exec pnpm version patch",
    "version:minor": "pnpm -r --filter './packages/*' exec pnpm version minor",
    "publish:all": "pnpm -r --filter './packages/*' publish --no-git-checks"
  },
  "keywords": [
    "filcronet",
    "framework"
  ],
  "author": "Filippo Crotti",
  "license": "UNLICENSED",
  "devDependencies": {
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.19.0"
}
